  "metadata": {
    "purpose": "This dataset describes various geospatial features or objects, providing key details on their type, function, and current status. Each record is uniquely identified by a name and indicates whether the feature is fixed or moveable. A critical attribute is 'depth', which defines the vertical position of each feature relative to a reference, suggesting a focus on subsurface or submerged elements. The dataset's geographic purpose is to map and characterize these features within a 3D space, facilitating analysis and management of objects with significant vertical components.",
    "keywords": [
      "geospatial",
      "data",
      "features",
      "assets",
      "infrastructure",
      "mobility",
      "objects"
    ]
  }
